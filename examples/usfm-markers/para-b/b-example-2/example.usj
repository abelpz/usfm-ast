        },
        "This is a prayer of the prophet Habakkuk:"
      ]
    },
    {
      "type": "para",
      "marker": "b"
    },
    {
      "type": "para",
      "marker": "q1",
      "content": [
        {
          "type": "verse",
          "marker": "v",
          "number": "2",
          "sid": "HAB 3:2"
        },
        "O ",
        {
          "type": "char",
          "marker": "nd",
          "content": ["Lord"]
        },
        ", I have heard of what you have done,"
      ]
    },
    {
      "type": "para",
      "marker": "q2",
      "content": ["and I am filled with awe."]
    }
