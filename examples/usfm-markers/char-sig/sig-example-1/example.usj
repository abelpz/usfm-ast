          "sid": "COL 4:18"
        },
        "With my own hand I write this: ",
        {
          "type": "char",
          "marker": "sig",
          "content": [
            "Greetings from Paul"
          ]
        },
        ". Do not forget my chains!"
      ]
    },
    {
      "type": "para",
      "marker": "cls",
      "content": [
        "May God's grace be with you."
      ]
