      "content": [
        {
          "marker": "v",
          "number": "2",
          "type": "verse",
          "sid": "HAB 3:2"
        },
        "O ",
        {
          "marker": "nd",
          "content": [
            "Lord"
          ],
          "type": "char"
        },
        ", I have heard of what you have done,"
      ]
    },
    {
      "type": "para",
      "marker": "q2",
      "content": [
        "and I am filled with awe."
      ]
    },
    {
      "type": "para",
      "marker": "q1",
      "content": [
        "Now do again in our times"
      ]
    },
    {
      "type": "para",
      "marker": "q2",
      "content": [
        "the great deeds you used to do."
      ]
    },
    {
      "type": "para",
      "marker": "q1",
      "content": [
        "Be merciful, even when you are angry."
      ]
    }
  ]
}
