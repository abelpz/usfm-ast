# Door43 / DCS (Gitea) — copy to `.env.door43` at the repo root (gitignored).
# Used by optional integration tests in `packages/usfm-editor-core/tests/door43/`.
#
# Create a personal access token: Gitea → Settings → Applications → Generate New Token
# (scope: at least **read** for `repo`; add **write** only if you enable write tests.)
#
# https://git.door43.org

# --- Required for read tests (`DOOR43_INTEGRATION=1`) ---
DOOR43_INTEGRATION=1
DOOR43_DCS_BASE_URL=https://git.door43.org
DOOR43_TOKEN=gitea_pat_xxxxxxxxxxxxxxxxxxxx
DOOR43_OWNER=your-org-or-user
DOOR43_REPO=your-test-repo
DOOR43_BRANCH=main

# Path to a USFM file in the repo (for `@usfm-tools/editor-adapters` `DcsGitSyncAdapter` reads / merge checks).
DOOR43_USFM_PATH=path/to/sample.usfm

# Journal file path for `createDcsJournalTransport` from `@usfm-tools/editor-adapters` (dedicated test file if you enable writes).
DOOR43_JOURNAL_PATH=usfm-ast/integration-test-journal.json

# --- Dangerous: only on a throwaway repo / branch ---
# DOOR43_ALLOW_WRITE=1

# Optional: WebSocket relay for combined realtime + DCS tests (`tests/door43/realtime-dcs.integration.test.ts`)
# RELAY_URL=ws://127.0.0.1:8787
