{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@usfm-tools/editor-core": ["../usfm-editor-core/src/index.ts"],
      "@usfm-tools/types": ["../shared-types/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
