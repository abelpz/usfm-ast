{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@usfm-tools/types": ["../shared-types/src/index.ts"],
      "@tauri-apps/plugin-store": ["./src/tauri/stubs/tauri-plugin-store.d.ts"],
      "@tauri-apps/plugin-fs": ["./src/tauri/stubs/tauri-plugin-fs.d.ts"],
      "@capacitor/preferences": ["./src/capacitor/stubs/capacitor-preferences.d.ts"],
      "@capacitor/network": ["./src/capacitor/stubs/capacitor-network.d.ts"],
      "@capacitor/filesystem": ["./src/capacitor/stubs/capacitor-filesystem.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
