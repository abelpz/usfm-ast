{
  "name": "@usfm-tools/checking",
  "version": "0.1.0",
  "description": "Checking workflow: stages, checklists, comments, decisions, text-reference resolution",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "bun run clean && tsc --build",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "jest",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@usfm-tools/types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.1.0",
    "typescript": "5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git",
    "directory": "packages/usfm-editor-checking"
  },
  "publishConfig": { "access": "public" }
}
