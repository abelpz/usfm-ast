{
  "name": "@usfm-tools/editor-adapters",
  "version": "0.1.0",
  "description": "USJ/USFM/USX helpers for editor apps — re-exports the adapter APIs ScriptureSession and shells rely on",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["usfm", "usj", "usx", "editor"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git",
    "directory": "packages/usfm-editor-adapters"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@usfm-tools/adapters": "workspace:*",
    "@usfm-tools/door43-rest": "workspace:*",
    "@usfm-tools/editor-core": "workspace:*",
    "@usfm-tools/parser": "workspace:*",
    "@usfm-tools/types": "workspace:*",
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/jszip": "3.4.1",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.3.5",
    "typescript": "5.9.3"
  }
}
