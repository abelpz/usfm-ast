{
  "name": "@usfm-tools/door43-rest",
  "version": "0.1.0",
  "description": "Minimal Gitea/Door43 REST client: repo contents list/read/create/update/delete (no auth helpers)",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "bun run clean && tsc --build",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "keywords": ["door43", "gitea", "dcs"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git",
    "directory": "packages/usfm-door43-rest"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.3.0",
    "rimraf": "^5.0.0",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  }
}
