{
  "name": "@usfm-tools/parser",
  "version": "0.1.0",
  "description": "USFM parsing and AST generation",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./oracle": {
      "types": "./dist/oracle/index.d.ts",
      "import": "./dist/oracle/index.js",
      "require": "./dist/oracle/index.js",
      "default": "./dist/oracle/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run clean && tsc --build",
    "build:watch": "tsc --build --watch",
    "playground": "bun __playground.js",
    "test": "jest --testPathIgnorePatterns=performance",
    "test:performance": "bun run build && jest --testPathPattern=performance",
    "test:watch": "jest --watch",
    "test:clean": "bun run clean && bun run test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@usfm-tools/types": "workspace:*",
    "@xmldom/xmldom": "0.8.11"
  },
  "keywords": [
    "usfm",
    "usj",
    "scripture",
    "bible",
    "parser"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git",
    "directory": "packages/usfm-parser"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
}