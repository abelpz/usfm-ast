{
  "name": "@usfm-tools/editor-ui",
  "version": "0.1.0",
  "description": "Headless WYSIWYG chrome for USFM ProseMirror: gutter, palette, bubble, conflict review",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./chrome-ui.css": "./chrome-ui.css"
  },
  "files": ["dist", "chrome-ui.css", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["usfm", "prosemirror", "wysiwyg", "editor"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git",
    "directory": "packages/usfm-editor-ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.6",
    "@usfm-tools/editor": "workspace:*",
    "@usfm-tools/editor-core": "workspace:*",
    "lucide": "1.7.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.38.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jsdom": "^24.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.3.5",
    "typescript": "6.0.3"
  }
}
