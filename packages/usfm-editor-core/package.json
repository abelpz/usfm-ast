{
  "name": "@usfm-tools/editor-core",
  "version": "0.1.0",
  "description": "Chapter chunking, alignment layer, and structured editing helpers for USJ",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run clean && tsc --build",
    "build:watch": "tsc --build --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@usfm-tools/adapters": "workspace:*",
    "@usfm-tools/parser": "workspace:*",
    "@usfm-tools/types": "workspace:*",
    "isomorphic-git": "1.27.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "ws": "^8.18.0"
  },
  "keywords": [
    "usfm",
    "usj",
    "alignment",
    "editor"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git",
    "directory": "packages/usfm-editor-core"
  },
  "publishConfig": {
    "access": "public"
  }
}
