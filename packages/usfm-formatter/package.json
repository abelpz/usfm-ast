{
  "name": "@usfm-tools/formatter",
  "version": "0.1.0",
  "description": "USFM formatting and normalization",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run clean && tsc --build",
    "build:watch": "tsc --build --watch",
    "test": "bun run build && jest --testPathIgnorePatterns=performance",
    "test:performance": "bun run build && jest --testPathPattern=performance",
    "test:watch": "jest --watch",
    "test:clean": "bun run clean && bun run test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@usfm-tools/parser": "workspace:*",
    "@usfm-tools/types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "usfm",
    "usj",
    "scripture",
    "bible",
    "parser"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/usfm-usj-monorepo.git",
    "directory": "packages/usfm-formatter"
  },
  "publishConfig": {
    "access": "public"
  }
}
