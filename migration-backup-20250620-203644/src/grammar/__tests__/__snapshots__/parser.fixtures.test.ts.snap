    "marker": "q2",
    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": "not addicted to wine,",
        "type": "text",
      },
    ],
    "marker": "q2",
    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": "not a brawler,",
        "type": "text",
      },
    ],
    "marker": "q2",
    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": "and not a greedy man.",
        "type": "text",
      },
    ],
    "marker": "q2",
    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": [
          {
            "content": "8",
            "type": "text",
          },
        ],
        "marker": "v",
        "type": "character",
      },
      {
        "content": "Instead, he should be:",
