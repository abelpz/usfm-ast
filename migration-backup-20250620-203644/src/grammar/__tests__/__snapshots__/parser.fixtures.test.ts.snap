    {
      "content": [
        {
          "content": [
            {
              "content": "7",
              "type": "text",
            },
          ],
          "marker": "v",
          "type": "character",
        },
        {
          "content": "For the overseer must be blameless, as God's household manager.",
          "type": "text",
        },
      ],
      "marker": "q1",
      "type": "paragraph",
    },
    {
      "content": [
        {
          "content": "He must not be arrogant,",
          "type": "text",
        },
      ],
      "marker": "q2",
      "type": "paragraph",
    },
    {
      "content": [
        {
          "content": "not easily angered,",
          "type": "text",
        },
      ],
      "marker": "q2",
      "type": "paragraph",
    },
    {
      "content": [
        {
          "content": "not addicted to wine,",
          "type": "text",
        },
      ],
      "marker": "q2",
      "type": "paragraph",
    },
    {
      "content": [
        {
          "content": "not a brawler,",
          "type": "text",
        },
      ],
      "marker": "q2",
      "type": "paragraph",
    },
    {
      "content": [
        {
          "content": "and not a greedy man.",
          "type": "text",
        },
      ],
      "marker": "q2",
      "type": "paragraph",
    },
  ],
}
`;

