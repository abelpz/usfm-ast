    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": "a friend of what is good,",
        "type": "text",
      },
    ],
    "marker": "li1",
    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": "sensible,",
        "type": "text",
      },
    ],
    "marker": "li1",
    "type": "paragraph",
  },
  {
    "content": [
      {
        "content": "righteous,",
