{
  "name": "usfm-usj-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for USFM and USJ tools and libraries",
  "repository": {
    "type": "git",
    "url": "https://github.com/abelpz/usfm-ast.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:usfm-parser-local": "cd packages/usfm-parser && bun run build && bunx jest --testPathIgnorePatterns=performance",
    "test:integration": "bunx jest tests/integration",
    "test:performance": "bunx jest tests/performance",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "publish:usfm": "node scripts/publish-scope.cjs @usfm-tools",
    "publish:usj": "node scripts/publish-scope.cjs @usj-tools",
    "publish:all": "node scripts/publish-scope.cjs @usfm-tools && node scripts/publish-scope.cjs @usj-tools",
    "deps:update": "bun update",
    "deps:check": "bun outdated",
    "do": "bun scripts/run-in-package.js",
    "examples": "bun tools/example-manager.js",
    "examples:check": "bun tools/example-manager.js check",
    "examples:generate": "bun tools/example-manager.js generate",
    "examples:create-usj": "bun tools/example-manager.js create-usj",
    "regenerate:example-usj": "bunx turbo run build --filter=@usfm-tools/parser && bun tools/regenerate-example-usj.ts",
    "oracles:compare": "node scripts/oracles/compare.mjs"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "usfm3": "0.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "commander": "14.0.0"
  }
}
