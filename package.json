{
  "name": "usfm-parser",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "usfm-perf": "./scripts/run-perf.js"
  },
  "files": [
    "dist",
    "README.md",
    "scripts/run-perf.js"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --no-cache",
    "perf": "./scripts/run-perf.js",
    "test:grammar": "jest src/grammar/__tests__/parser.*.test.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "performance-now": "^2.1.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "yargs": "^17.7.2"
  }
}
