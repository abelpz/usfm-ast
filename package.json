{
  "name": "@usfm/parser",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "usfm-perf": "./scripts/run-perf.js"
  },
  "files": [
    "dist",
    "README.md",
    "scripts/run-perf.js"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --no-cache",
    "perf": "./scripts/run-perf.js",
    "test:grammar": "jest src/grammar/__tests__/parser.*.test.ts",
    "usx2usj": "node scripts/usx-to-usj.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "generate-schema": "ts-node scripts/generate-schema.ts"
  },
  "devDependencies": {
    "@biblionexus-foundation/scripture-utilities": "^0.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "@types/xml2js": "^0.4.14",
    "@types/xmldom": "^0.1.34",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "performance-now": "^2.1.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-json-schema": "^0.65.1",
    "xml-beautify": "^1.2.3",
    "xml2js": "^0.6.2",
    "xmldom": "^0.6.0",
    "yargs": "^17.7.2"
  }
}