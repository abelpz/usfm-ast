{
  "name": "usfm-usj-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for USFM and USJ tools and libraries",
  "scripts": {
    "build": "pnpm --filter \"usfm-*\" run build",
    "test": "pnpm --filter \"usfm-*\" run test",
    "test:integration": "jest tests/integration",
    "test:performance": "jest tests/performance",
    "lint": "pnpm --filter \"usfm-*\" run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "clean": "pnpm -r run clean",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "format": "pnpm --filter \"usfm-*\" run format",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "publish:usfm": "pnpm -r --filter=\"@usfm-tools/*\" publish",
    "publish:usj": "pnpm -r --filter=\"@usj-tools/*\" publish",
    "publish:all": "pnpm -r publish",
    "version:patch": "pnpm -r exec -- npm version patch",
    "version:minor": "pnpm -r exec -- npm version minor",
    "version:major": "pnpm -r exec -- npm version major",
    "deps:update": "pnpm -r update",
    "deps:check": "pnpm -r outdated",
    "do": "node ./scripts/run-in-package.js",
    "examples": "node tools/example-manager.js",
    "examples:check": "node tools/example-manager.js check",
    "examples:generate": "node tools/example-manager.js generate",
    "examples:create-usj": "node tools/example-manager.js create-usj"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "commander": "14.0.0"
  }
}