# QA / multi-user integration tests — copy to `.env.qa` at the repo root (gitignored).
#
# Tests connect to qa.door43.org using three separate user accounts to exercise
# the 3-tier branch strategy (each user's branch → book branch → main).
#
# Credentials are username + password (NOT a PAT). Each test run acquires a
# short-lived token via Gitea Basic Auth and revokes it on teardown.
#
# Set QA_INTEGRATION=1 to opt-in to running these tests:
#   QA_INTEGRATION=1 bun run test --filter=@usfm-tools/editor-adapters
#
# ----------------------------------------------------------------------------
# Host
# ----------------------------------------------------------------------------
QA_HOST=https://qa.door43.org

# ----------------------------------------------------------------------------
# Test users (fill in your qa.door43.org credentials)
# ----------------------------------------------------------------------------
QA_USER1_USERNAME=
QA_USER1_PASSWORD=

QA_USER2_USERNAME=
QA_USER2_PASSWORD=

# ----------------------------------------------------------------------------
# Shared test organisation (optional — only needed for org-scoped tests).
# If left blank, integration tests create repos under User 1's personal
# account and add User 2 as a collaborator automatically.
# ----------------------------------------------------------------------------
QA_TEST_ORG=

# ----------------------------------------------------------------------------
# Optional: base name for test repositories created during runs.
# Repositories are named  {QA_REPO_PREFIX}-{timestamp}  and deleted on teardown.
# ----------------------------------------------------------------------------
QA_REPO_PREFIX=usfm-ast-test
